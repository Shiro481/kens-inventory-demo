FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy the rest of the application
# We use a volume mount for local development, 
# but copying here ensures the image is semi-functional standalone.
COPY . .

# Expose Vite's default port
EXPOSE 5173

# Run Vite with --host flag to allow connections from outside the container
CMD ["npm", "run", "dev", "--", "--host"]
